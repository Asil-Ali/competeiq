# ── REQUIRED ──────────────────────────────────────────────────

# Telegram bot token — from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# Your Telegram user ID — from @userinfobot
ADMIN_IDS=123456789

# OpenRouter API key — from openrouter.ai (main AI agent)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Brave Search API key — from api.search.brave.com (free 2000/month)
BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── REQUIRED FOR PRODUCTION ───────────────────────────────────

# Groq API key — from console.groq.com (free, independent evaluator)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — from supabase.com project settings → API
# Required for: persistent memory + rate limiting across restarts
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── OPTIONAL ──────────────────────────────────────────────────

# Override default AI model (default: google/gemini-2.0-flash-exp:free)
# AI_MODEL=google/gemini-2.0-flash-exp:free

# Override default Groq evaluator model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
